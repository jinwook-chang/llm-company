# Select one: mock, openai, azure_openai, vertex
LLM_WIKI_PROVIDER=vertex

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Vertex AI / Google GenAI
GOOGLE_CLOUD_PROJECT=genbi-dev
GOOGLE_CLOUD_LOCATION=global
VERTEX_MODEL=gemini-3-flash-preview
VERTEX_EMBEDDING_MODEL=gemini-embedding-2-preview